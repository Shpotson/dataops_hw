# DB
POSTGRES_USER=lakefs_user
POSTGRES_PASSWORD=secure_lakefs
POSTGRES_DB=lakefs
PGDATA=/var/lib/postgresql/data

# MINIO
MINIO_ROOT_USER=minio_root
MINIO_ROOT_PASSWORD=minio_strong_pass
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SERVER_ENDPOINT=http://minio:9000

# LAKES
LAKEFS_BLOCKSTORE_TYPE=s3
LAKEFS_BLOCKSTORE_S3_ENDPOINT=http://minio:9000
LAKEFS_BLOCKSTORE_S3_REGION=us-east-1
LAKEFS_BLOCKSTORE_S3_FORCE_PATH_STYLE=true
LAKEFS_DATABASE_TYPE=postgres
LAKEFS_DATABASE_CONNECTION_STRING=postgresql://lakefs_user:secure_lakefs@postgres:5432/lakefs?sslmode=disable

# LAKEFS auth
LAKEFS_AUTH_ENCRYPT_SECRET_KEY=fake_encryption_secret_12345678901234567890
LAKEFS_AUTH_ROOT_BCRYPT_COST=10

# LAKECTL UI / CLI
LAKEFS_INSTALLATION_USER_NAME=lakefs_admin
LAKEFS_INSTALLATION_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
LAKEFS_INSTALLATION_SECRET_ACCESS_KEY=YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
LAKECTL_CREDENTIALS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
LAKECTL_CREDENTIALS_SECRET_ACCESS_KEY=YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
LAKECTL_SERVER_ENDPOINT_URL=http://lakefs:8000